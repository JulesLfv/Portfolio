---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Mentions légales — {siteConfig.name}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white font-mono">
    <div class="mx-auto max-w-3xl px-6 py-16 lg:px-8">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-800 transition-colors mb-10"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
          <path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" />
        </svg>
        Retour au portfolio
      </a>

      <h1 class="text-3xl font-bold text-gray-900 mb-10">Mentions légales</h1>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-800 mb-3">Éditeur du site</h2>
        <p class="text-gray-600 leading-relaxed">
          {siteConfig.name}<br />
          Email : <a href={`mailto:${siteConfig.social.email}`} class="underline hover:text-gray-900">{siteConfig.social.email}</a>
        </p>
      </section>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-800 mb-3">Hébergement</h2>
        <p class="text-gray-600 leading-relaxed">
          Vercel Inc.<br />
          340 Pine Street, Suite 1200<br />
          San Francisco, CA 94104 — États-Unis<br />
          <a href="https://vercel.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-900">vercel.com</a>
        </p>
      </section>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-800 mb-3">Données personnelles</h2>
        <p class="text-gray-600 leading-relaxed">
          Ce site ne collecte aucune donnée personnelle et n'utilise pas de cookies. Aucun formulaire de collecte n'est présent.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-gray-800 mb-3">Propriété intellectuelle</h2>
        <p class="text-gray-600 leading-relaxed">
          L'ensemble du contenu de ce site (textes, descriptions, structure) est la propriété de {siteConfig.name}. Toute reproduction sans autorisation est interdite.
        </p>
      </section>
    </div>
  </body>
</html>
